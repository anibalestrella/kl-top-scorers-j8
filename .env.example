# Google Sheets proxy — required for /api/sheets to succeed.
# Copy this file to .env.local for local dev (`vercel dev`),
# and configure the same vars in Vercel project settings for production.

# Google Cloud API key with "Google Sheets API" enabled.
# Recommended: restrict the key to the Sheets API + your Vercel domain(s).
GOOGLE_SHEETS_API_KEY=

# Spreadsheet ID (the long string in the sheet URL).
# Default if unset: 1upLKRlbi6E4xq66xloy57KDE_DNCkjkVix9DYzZ0jTs
GOOGLE_SHEETS_ID=1upLKRlbi6E4xq66xloy57KDE_DNCkjkVix9DYzZ0jTs

# A1 notation for the data range. Default if unset: Sheet1!A1:D50
GOOGLE_SHEETS_RANGE=Sheet1!A1:D50
